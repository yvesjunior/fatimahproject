# Production Docker Compose config
# Copy this to .env on your production server and fill in values

WEB_PORT=80
APP_KEY=GENERATE_NEW_KEY
APP_URL=https://yourdomain.com

# MariaDB on host machine
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=fatimaproject
DB_USERNAME=fatimaproject
DB_PASSWORD=CHANGE_ME
